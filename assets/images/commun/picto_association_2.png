    <div id="adherents" class="contenu">

        <h1>Espace adhérents</h1>

        <div class="content">
            <div class="zone_wrap">


                <div class="zone_login">
                    <div class="zone_reset"></div>

                    <div class="loginForm">
    <div class="loginMessage"></div>

    <div class="loginLogin">

        
        <form class="loginLoginForm" action="espace-adherents.html" method="post">


            <legend class="loginLegend">Pour accéder à votre espace réservé, veuillez remplir les champs :</legend>

            <p class="champ">
                <label class="loginUsernameLabel" for="username">e-mail :</label>
                <input class="loginUsername" type="text" name="username" id="username" placeholder="votre email"/>
            </p>

            <p class="champ">
                <label class="loginPasswordLabel" for="password">mot de passe :</label>
                <input class="loginPassword" type="password" name="password" id="password"
                       placeholder="votre mot de passe"/>
            </p>

            <button class="btn_oublie" type="button" onclick="$('.zone_oubli').addClass('active');">Mot de passe oublié ?</button>

            <input class="returnUrl" type="hidden" name="returnUrl" value="/assets/components/francedouglas/templates/img/commun/picto_association_2.png"/>
            <input class="loginLoginValue" type="hidden" name="service" value="login"/>
            

            <p class="loginLoginButton"><input class="btn_login" type="submit" name="Login" value="Connexion"/></span>

        </form>
        

    </div>
</div>
                    <div class="zone_oubli">
                        <div class="loginFPErrors"></div>
<div class="loginFP">
    <form class="loginFPForm" action="espace-adherents.html" method="post">
        <fieldset class="loginFPFieldset">
            <legend class="loginFPLegend">Mot de passe oublié</legend>
            <label class="loginFPUsernameLabel">Identifiant
                <input class="loginFPUsername" type="text" name="username" value="" />
            </label>
            
            <p>Oublié votre identifiant ?</p>
            
            <label class="loginFPEmailLabel">Adresse email
                <input class="loginFPEmail" type="text" name="email" value="" />
            </label>
            
            <input class="returnUrl" type="hidden" name="returnUrl" value="/assets/components/francedouglas/templates/img/commun/picto_association_2.png" />
            
            <input class="loginFPService" type="hidden" name="login_fp_service" value="forgotpassword" />
            <span class="loginFPButton"><input type="submit" name="login_fp" value="Réinitialiser le mot de passe" /></span>
        </fieldset>
    </form>
</div>
                    </div>

                </div>
