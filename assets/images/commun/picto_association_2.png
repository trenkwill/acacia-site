  <div id="footer_contact">
    <div class="zone_wrap">

      <div class="col1">
        <img src="assets/components/francedouglas/templates/img/commun/logo-footer.png"
             alt="logo france Douglas" style="width:200px;height:150px;">
        <p class="adresse">
          France Douglas<br />
78, rue Jules Ferry<br />
33200 Bordeaux
          <br>Tél : 06 62 81 15 46<br>
          <a href="mailto:contact@france-douglas.com" title="Contactez-nous">contact@france-douglas.com</a>
        </p>
        <a class="bouton bleu" href="contact-et-localisation.html" title="Voir la page contact">Contact et localisation</a>
      </div>
      <!-- fon col1 -->

      <div class="col2">
        <h2>Lettre d'information</h2>
        <p class="infos">Veuillez remplir les champs ci-dessous<br>
          (ces informations resteront confidentielles).</p>
        <form action="outils/webservices.html?a=sendinblue" method="POST">
          <p>
            <label for="newsletter_nom">Nom</label>
            <input type="text" id="newsletter_nom" name="newsletter_nom" value=""
                   placeholder="Nom" required>
          </p>
          <p>
            <label for="newsletter_prenom">Prénom</label>
            <input type="text" id="newsletter_prenom"  name="newsletter_prenom" value=""
                   placeholder="Prénom" required>
          </p>
          <p>
            <label for="newsletter_societe">Société (optionnel)</label>
            <input type="text" id="newsletter_societe" name="newsletter_societe" value=""
                   placeholder="Société (optionnel) ">
          </p>
          <p>
            <label for="newsletter_email">E-mail</label>
            <input type="email" id="newsletter_email" name="newsletter_email" value=""
                   placeholder="E-mail" required>
          </p>
          <button class="btn_submit" type="submit">Envoyer
          </button>
        </form>
      </div>
